# ---- Configuração do servidor WhatsApp não-oficial (Baileys) ----
# Copie para o painel do Railway em Variables (não suba o .env real para o Git)

# Segredo que o CRM usa para chamar /send. Crie uma senha forte (ex: 32 caracteres).
API_TOKEN=troque-por-um-segredo-forte

# Supabase (mesmos do seu projeto) — para gravar as respostas recebidas
SUPABASE_URL=https://SEUPROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui

# Pasta da sessão do WhatsApp. No Railway, crie um Volume montado em /app/auth
AUTH_DIR=/app/auth

# Atraso mínimo entre envios em milissegundos (anti-ban). Ex: 8000 = 8s. 0 = sem atraso.
MIN_DELAY_MS=8000
